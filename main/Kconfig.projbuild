menu "WiFi Configuration"

    config ESP_WIFI_SSID
        string "WiFi SSID"
        default "jhome"
        help
            SSID (network name) for the ESP32 to connect to.

    config ESP_WIFI_PASSWORD
        string "WiFi Password"
        default "123698745"
        help
            WiFi password (WPA or WPA2) for the ESP32 to use.

endmenu
